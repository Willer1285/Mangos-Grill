# ============================================
# Mango's Grill - Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values

# --- Base de Datos ---
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/mangos-grill

# --- NextAuth.js ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here-generate-with-openssl-rand-base64-32

# --- OAuth Providers ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# --- Stripe (Pagos con tarjeta) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend (Correos transaccionales) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@mangosgrill.com

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Mango's Grill

# --- Impuesto Texas (8.25%) ---
NEXT_PUBLIC_TX_TAX_RATE=0.0825
